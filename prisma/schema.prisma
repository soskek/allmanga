generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "debian-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String             @id @default(cuid())
  email         String             @unique
  displayName   String?
  role          String             @default("member")
  createdAt     DateTime           @default(now())
  updatedAt     DateTime           @updatedAt
  authIdentities AuthIdentity[]
  sessions       Session[]
  workPrefs     UserWorkPref[]
  releaseStates UserReleaseState[]
  settings      UserSetting[]
}

model AuthIdentity {
  id                String   @id @default(cuid())
  userId            String
  provider          String
  providerAccountId String
  email             String
  displayName       String?
  avatarUrl         String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
  @@index([email])
}

model Session {
  id        String   @id @default(cuid())
  tokenHash String   @unique
  userId    String
  expiresAt DateTime
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
}

model Site {
  id           String    @id
  name         String
  enabled      Boolean   @default(true)
  baseUrl      String
  syncStrategy String
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  works        Work[]
  releases     Release[]
  syncRuns     SyncRun[]
}

model Work {
  id              String         @id
  siteId          String
  canonicalUrl    String
  title           String
  authors         String
  kind            String
  status          String
  descriptionText String?
  firstSeenAt     DateTime       @default(now())
  lastSeenAt      DateTime       @default(now())
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
  site            Site           @relation(fields: [siteId], references: [id], onDelete: Cascade)
  releases        Release[]
  prefs           UserWorkPref[]

  @@unique([siteId, canonicalUrl])
  @@index([siteId, title])
}

model Release {
  id                 String             @id
  siteId             String
  workId             String?
  canonicalUrl       String
  title              String?
  publishedAt        DateTime?
  firstSeenAt        DateTime          @default(now())
  sourceType         String
  rawBadgeText       String?
  semanticKind       String
  semanticConfidence Float             @default(0)
  semanticSignals    String
  defaultVisibility  String
  contentKind        String
  extraJson          String?
  createdAt          DateTime          @default(now())
  updatedAt          DateTime          @updatedAt
  site               Site               @relation(fields: [siteId], references: [id], onDelete: Cascade)
  work               Work?              @relation(fields: [workId], references: [id], onDelete: SetNull)
  userStates         UserReleaseState[]

  @@unique([siteId, canonicalUrl])
  @@index([workId, publishedAt])
  @@index([semanticKind, firstSeenAt])
}

model UserWorkPref {
  id               String   @id @default(cuid())
  userId           String
  workId           String
  follow           Boolean  @default(false)
  mute             Boolean  @default(false)
  pin              Boolean  @default(false)
  priority         Int      @default(0)
  catchupMode      String   @default("all")
  showSideStory    String   @default("collapsed")
  showIllustration String   @default("collapsed")
  showPromotion    String   @default("hidden")
  followedAt       DateTime @default(now())
  followFromStart  Boolean  @default(false)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  user             User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  work             Work     @relation(fields: [workId], references: [id], onDelete: Cascade)

  @@unique([userId, workId])
  @@index([follow, mute, pin, priority])
}

model UserReleaseState {
  id            String   @id @default(cuid())
  userId        String
  releaseId     String
  state         String
  lane          String
  openedAt      DateTime?
  readAt        DateTime?
  dismissedAt   DateTime?
  overrideKind  String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  release       Release  @relation(fields: [releaseId], references: [id], onDelete: Cascade)

  @@unique([userId, releaseId])
  @@index([state, lane])
}

model SyncRun {
  id         String   @id @default(cuid())
  siteId     String
  status     String
  startedAt  DateTime @default(now())
  finishedAt DateTime?
  statsJson  String
  errorText  String?
  site       Site     @relation(fields: [siteId], references: [id], onDelete: Cascade)

  @@index([siteId, startedAt])
}

model AppSetting {
  key       String   @id
  value     String
  updatedAt DateTime @updatedAt
}

model UserSetting {
  id        String   @id @default(cuid())
  userId    String
  key       String
  value     String
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, key])
  @@index([userId])
}
